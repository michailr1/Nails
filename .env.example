# Required. Use an IANA timezone; there is deliberately no default.
APP_TIMEZONE=Europe/Berlin

# Example only. Production uses a separately generated secret.
INTERNAL_API_KEY=example-only-internal-api-key-not-secret

# The API connects with the restricted application role, never the bootstrap admin.
DATABASE_URL=postgresql+psycopg://nails_app:change-app-password@nails-db:5432/nails

# PostgreSQL bootstrap account. Used only by the container entrypoint.
POSTGRES_DB=nails
POSTGRES_ADMIN_USER=nails_admin
POSTGRES_ADMIN_PASSWORD=change-admin-password

# Restricted application role created during first database initialization.
APP_DB_USER=nails_app
APP_DB_PASSWORD=change-app-password

# Bind the API only to loopback on the VPS.
NAILS_API_BIND=127.0.0.1
NAILS_API_PORT=8210
