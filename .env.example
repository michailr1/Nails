# Required. Use an IANA timezone; there is deliberately no default.
APP_TIMEZONE=Europe/Berlin

# Local-only example. Production values belong in /opt/nails/.env with mode 600.
DATABASE_URL=postgresql+psycopg://nails_app:change-me@nails-db:5432/nails

# Docker Compose database bootstrap values. Do not reuse credentials from other projects.
POSTGRES_DB=nails
POSTGRES_USER=nails_app
POSTGRES_PASSWORD=change-me

# Bind the API only to loopback on the VPS.
NAILS_API_BIND=127.0.0.1
NAILS_API_PORT=8210
